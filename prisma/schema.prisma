generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  AUDIENCE
  CREATOR
  ADMIN
}

enum CreatorType {
  PRODUCT
  SERVICE
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String          @unique
  password       String?
  country        String?
  role           Role            @default(AUDIENCE)
  createdAt      DateTime        @default(now())
  articles       Article[]
  creatorProfile CreatorProfile?
  orders         Order[]
}

model CreatorProfile {
  id          String      @id @default(cuid())
  brandName   String
  creatorType CreatorType
  category    String
  cacDocument String
  trialEndsAt DateTime
  userId      String      @unique
  user        User        @relation(fields: [userId], references: [id])
  products    Product[]
  services    Service[]
}

model Product {
  id          String         @id @default(cuid())
  title       String
  description String
  price       Float
  image       String?
  creatorId   String
  createdAt   DateTime       @default(now())
  creator     CreatorProfile @relation(fields: [creatorId], references: [id])
}

model Service {
  id          String         @id @default(cuid())
  title       String
  description String
  price       Float
  creatorId   String
  createdAt   DateTime       @default(now())
  creator     CreatorProfile @relation(fields: [creatorId], references: [id])
}

model Order {
  id        String   @id @default(cuid())
  amount    Float
  status    String
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Article {
  id        String   @id @default(cuid())
  title     String
  content   String
  image     String?
  authorId  String
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
}